{
	"name": "sccharts-interpreter",
	"version": "0.1.0",
	"description": "Interpreter for the synchronous language SCChart",
	"type": "module",
	"bin": {
		"sccharts-interpreter": "./bin/sccharts-interpreter"
	},
	"scripts": {
		"build": "tsc",
		"start": "",
		"core": "node dist/core.js",
		"simulation": "node dist/simulation.js",
		"webui": "node dist/webui.js",
		"compiler-server": "node dist/compiler-server.js",
		"web-dev": "vite --port 5173",
		"web-build": "vite build",
		"all": "concurrently \"npm run core\" \"npm run webui\" \"npm run compiler-server\"",
		"test": "cd testing && uv run run_tests.py"
	},
	"dependencies": {
		"@types/cors": "^2.8.19",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1",
		"cors": "^2.8.6",
		"express": "^5.2.1"
	},
	"devDependencies": {
		"@types/express": "^5.0.6",
		"@types/node": "^22.20.0",
		"concurrently": "^10.0.3",
		"typescript": "^5.6.0",
		"vite": "^7.3.6",
		"vitest": "^3.0.0",
		"wait-on": "^9.0.10"
	}
}
